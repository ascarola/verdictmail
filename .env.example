# VerdictMail — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Gmail credentials
GMAIL_USERNAME=your.address@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# AI provider API keys — only the key for your chosen provider is required
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_API_KEY=

# URLhaus threat intelligence — optional
# Free API key from https://abuse.ch/ (register, then find your key under your profile)
URLHAUS_API_KEY=

# VirusTotal threat intelligence — optional
# Free API key from https://www.virustotal.com (register, then find your key under your profile)
VIRUSTOTAL_API_KEY=
